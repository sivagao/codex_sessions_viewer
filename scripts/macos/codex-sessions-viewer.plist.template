<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>local.codex-sessions-viewer.bridge</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd __REPO_ROOT__ && pnpm bridge:start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__REPO_ROOT__/tmp/codex-sessions-viewer-bridge.out.log</string>
    <key>StandardErrorPath</key>
    <string>__REPO_ROOT__/tmp/codex-sessions-viewer-bridge.err.log</string>
  </dict>
</plist>
