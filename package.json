{
  "name": "codex-sessions-viewer",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r build",
    "bridge:doctor": "pnpm --filter @csv/api daemon doctor",
    "bridge:open": "pnpm --filter @csv/api daemon open",
    "bridge:start": "pnpm --filter @csv/api daemon start",
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @csv/api dev\" \"pnpm --filter @csv/web dev\"",
    "package:mac": "pnpm build && tsx scripts/macos/package-bridge.ts",
    "test": "pnpm -r test",
    "check": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
